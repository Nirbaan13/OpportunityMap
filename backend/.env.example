# Database — local Docker or Neon
# Neon example:
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg://opportunitymap:opportunitymap_dev@localhost:5432/opportunitymap

# Security (generate a random string for production)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Public site URL (links inside reminder emails)
FRONTEND_URL=http://localhost:3000

# App
APP_NAME=OpportunityMap API
ENVIRONMENT=development
DEBUG=true
ALLOW_DEV_PREMIUM_UNLOCK=false

# SMTP — deadline reminders email the user's registered address.
# Leave SMTP_HOST empty to skip email (website Alerts inbox still works).
# Example (Gmail app password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=OpportunityMap <you@gmail.com>
# SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Premium (yearly membership).
PREMIUM_PRICE_INR=299
# Polar product price (not shown on site). Keep in sync with Polar dashboard.
PREMIUM_PRICE_USD=3.99
# Razorpay keys from https://dashboard.razorpay.com/app/keys
# Local test unlock additionally requires ALLOW_DEV_PREMIUM_UNLOCK=true.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Create this separately in Razorpay Dashboard > Webhooks.
RAZORPAY_WEBHOOK_SECRET=
# Polar international yearly subscription (https://polar.sh)
# Create a recurring yearly $3.99 product, then paste Product ID + access token.
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
# Use https://sandbox-api.polar.sh/v1 while testing in Polar sandbox.
POLAR_API_BASE=https://api.polar.sh/v1
