# Database
DATABASE_URL=postgresql+psycopg://opportunitymap:opportunitymap_dev@localhost:5432/opportunitymap

# Security (generate a random string for production)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Public site URL (links inside reminder emails)
FRONTEND_URL=http://localhost:3000

# App
APP_NAME=OpportunityMap API
DEBUG=true

# SMTP — deadline reminders email the user's registered address.
# Leave SMTP_HOST empty to skip email (website Alerts inbox still works).
# Example (Gmail app password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=OpportunityMap <you@gmail.com>
# SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Premium (yearly INR membership). Change PREMIUM_PRICE_INR anytime.
PREMIUM_PRICE_INR=299
# Razorpay keys from https://dashboard.razorpay.com/app/keys
# Leave empty + DEBUG=true to use /payments/dev-unlock for local testing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
